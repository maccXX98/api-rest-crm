    "security": {
        "authentication": {
            "mechanism": "JWT (JSON Web Tokens)",
            "implementation": "NestJS JWT module with custom AuthGuard",
            "token_types": [
                {
                    "type": "access_token",
                    "purpose": "API access authorization",
                    "expiration": "1 hour",
                    "storage": "Client-side (typically in memory or secure storage)"
                },
                {
                    "type": "refresh_token",
                    "purpose": "Obtaining new access tokens without re-authentication",
                    "expiration": "180 days",
                    "storage": "Client-side (secure storage)"
                }
            ]
        },
        "authorization": {
            "mechanism": "Role-based access control",
            "roles": [
                "User roles stored in the User entity"
            ]
        },
        "password_security": {
            "hashing": "bcrypt",
            "validation": "Server-side validation using class-validator"
        },
        "api_security": {
            "global_prefix": "All endpoints are prefixed with /api",
            "public_endpoints": [
                "/api/auth/login",
                "/api/auth/refresh"
            ],
            "protected_endpoints": "All other endpoints require a valid JWT token"
        }
    }
