{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022", // Optimizado para Node.js modernos
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true, // Activa todas las protecciones automáticamente
    "strictPropertyInitialization": false, // Desactivado para evitar errores en Entidades de TypeORM
    "forceConsistentCasingInFileNames": true, // Vital para tu flujo Windows/Linux
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true
  },
  "exclude": ["node_modules", "dist", "test", "**/*.spec.ts"]
}